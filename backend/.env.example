PORT=3001
FRONTEND_URL=http://localhost:5173

# Global default provider (used by both agents unless overridden per-role below)
LLM_PROVIDER=claude

# Global default model (optional) — overrides provider's default model
# LLM_MODEL=claude-opus-4-1

# Per-agent-role overrides (optional) — let context & render agents use
# different providers/models, and even different base URLs/keys
# CONTEXT_LLM_PROVIDER=
# CONTEXT_LLM_MODEL=
# CONTEXT_LLM_BASE_URL=
# CONTEXT_LLM_API_KEY=
# RENDER_LLM_PROVIDER=
# RENDER_LLM_MODEL=
# RENDER_LLM_BASE_URL=
# RENDER_LLM_API_KEY=

# Credentials — REQUIRED for whichever provider(s) are selected above.
# These are no longer configurable via the Settings UI / stored in the database.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ZAI_API_KEY=
GOOGLE_API_KEY=
CUSTOM_BASE_URL=http://localhost:11434/v1
CUSTOM_API_KEY=ollama
CUSTOM_MODEL=llama3

NEWS_API_KEY=

# Google OAuth (Gmail + Calendar), read-only scopes — see docs/ENGINEERING.md §3
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Loopback redirect target; defaults to http://localhost:$PORT/api/connections/google/callback
# GOOGLE_REDIRECT_URI=

# RSS fallback used when NewsAPI is rate-limited, errors, or NEWS_API_KEY is
# unset. Comma-separated feed URLs; sensible finance/tech/AI defaults are
# shipped in news/rss.js if left unset.
# RSS_FEEDS=

# Weather location (seeded into database on first start)
WEATHER_LAT=
WEATHER_LON=
WEATHER_CITY=
